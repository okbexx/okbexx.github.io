---
export interface Props {
  title: string;
  description?: string;
  article?: boolean;
}

const { title, description = 'AI 超级个体的活标本 — 一个人用 AI 工具栈跑出团队级产出', article = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Jarl</title>
  <meta name="description" content={description} />
  <meta name="author" content="Jarl" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {article && <meta property="article:author" content="Jarl" />}
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap');

    :root {
      --bg: #0D1117;
      --bg-card: #161B22;
      --bg-card-hover: #1C2128;
      --border: rgba(139,148,158,0.12);
      --text: #E6EDF3;
      --text-secondary: #8B949E;
      --blue: #38BDF8;
      --orange: #F97316;
      --purple: #A78BFA;
      --green: #34D399;
      --font-sans: 'Noto Sans SC', -apple-system, sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-sans);
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: var(--blue);
      text-decoration: none;
      transition: color 0.2s;
    }
    a:hover { color: var(--purple); }

    /* subtle grid background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(56,189,248,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(56,189,248,0.02) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    /* nav */
    .nav {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 900px;
      margin: 0 auto;
      padding: 32px 24px;
    }
    .nav-brand {
      font-size: 20px;
      font-weight: 900;
      color: var(--text);
      letter-spacing: -0.5px;
    }
    .nav-brand span { color: var(--blue); }
    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-size: 15px;
      font-weight: 500;
      color: var(--text-secondary);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }

    /* main */
    .main {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px 80px;
    }

    /* footer */
    .footer {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 24px;
      border-top: 1px solid var(--border);
      text-align: center;
      color: var(--text-secondary);
      font-size: 14px;
    }
    .footer a { color: var(--text-secondary); }
    .footer a:hover { color: var(--blue); }

    /* article content */
    .prose {
      max-width: 700px;
      margin: 0 auto;
    }
    .prose h1 {
      font-size: 36px;
      font-weight: 900;
      line-height: 1.3;
      margin: 60px 0 20px;
    }
    .prose h2 {
      font-size: 26px;
      font-weight: 700;
      line-height: 1.4;
      margin: 48px 0 16px;
      color: var(--blue);
    }
    .prose h3 {
      font-size: 20px;
      font-weight: 700;
      margin: 36px 0 12px;
    }
    .prose p {
      margin: 16px 0;
      font-size: 17px;
      line-height: 1.8;
      color: var(--text);
    }
    .prose ul, .prose ol {
      margin: 16px 0;
      padding-left: 24px;
    }
    .prose li {
      margin: 8px 0;
      font-size: 17px;
      line-height: 1.7;
    }
    .prose strong { color: var(--orange); font-weight: 700; }
    .prose code {
      font-family: var(--font-mono);
      background: rgba(56,189,248,0.08);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 15px;
      color: var(--blue);
    }
    .prose pre {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 24px;
      margin: 20px 0;
      overflow-x: auto;
    }
    .prose pre code {
      background: none;
      padding: 0;
      color: var(--text);
    }
    .prose blockquote {
      border-left: 4px solid var(--purple);
      background: rgba(167,139,250,0.06);
      padding: 16px 24px;
      margin: 20px 0;
      border-radius: 0 8px 8px 0;
    }
    .prose blockquote p { color: var(--text-secondary); }
    .prose hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 40px 0;
    }
    .prose img {
      max-width: 100%;
      border-radius: 12px;
      margin: 20px 0;
    }

    /* blog list */
    .blog-list { list-style: none; }
    .blog-item {
      display: block;
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
    }
    .blog-item:last-child { border-bottom: none; }
    .blog-item-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 8px;
      transition: color 0.2s;
    }
    a:hover .blog-item-title { color: var(--blue); }
    .blog-item-desc {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 8px;
    }
    .blog-item-meta {
      font-size: 13px;
      color: var(--text-secondary);
      display: flex;
      gap: 16px;
    }
    .blog-item-tag {
      background: rgba(56,189,248,0.08);
      color: var(--blue);
      padding: 2px 10px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 500;
    }

    /* meta line */
    .article-meta {
      display: flex;
      gap: 16px;
      align-items: center;
      color: var(--text-secondary);
      font-size: 14px;
      margin-bottom: 40px;
    }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-brand">Jarl<span>.</span>dev</a>
    <ul class="nav-links">
      <li><a href="/">首页</a></li>
      <li><a href="/blog">博客</a></li>
      <li><a href="/about">关于</a></li>
    </ul>
  </nav>

  <main class="main">
    <slot />
  </main>

  <footer class="footer">
    <p>© 2026 Jarl · 用 AI 构建个人知识操作系统</p>
    <p style="margin-top:8px;">
      <a href="https://github.com/okbexx" target="_blank">GitHub</a>
      ·
      <a href="https://x.com/okbexx" target="_blank">X / Twitter</a>
    </p>
  </footer>
</body>
</html>
