---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('blog');
const posts = entries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="Jarl — 用 AI 做超级个体">
  <!-- Hero -->
  <section style="padding: 60px 0 40px;">
    <p style="color: var(--blue); font-size: 15px; font-weight: 500; margin-bottom: 16px; letter-spacing: 2px;">AI 超级个人 · 工程师 · 内容创作者</p>
    <h1 style="font-size: 48px; font-weight: 900; line-height: 1.2; margin-bottom: 20px;">
      一个人 + AI<br>
      <span style="background: linear-gradient(135deg, var(--blue), var(--purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">跑出团队级产出</span>
    </h1>
    <p style="font-size: 18px; color: var(--text-secondary); max-width: 560px; line-height: 1.7;">
      我叫 Jarl。我在探索一个人如何通过 AI 工具栈和系统设计，获得接近一个团队的产出能力。
    </p>
  </section>

  <!-- Projects -->
  <section style="padding: 40px 0;">
    <h2 style="font-size: 14px; font-weight: 700; color: var(--text-secondary); letter-spacing: 3px; margin-bottom: 24px; text-transform: uppercase;">我在做什么</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">

      <a href="/distill" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; transition: border-color 0.2s; text-decoration: none;">
        <div style="font-size: 28px; margin-bottom: 12px;">🧪</div>
        <div style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 8px;">Distill · 知识蒸馏塔</div>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          一套真实的知识蒸馏系统。碎片信息从塔底进入，经过对象分类、层层晋升、淘汰废液，变成可复用的知识精华。不是方法论，是我每天都在跑的操作系统。
        </p>
      </a>

      <a href="/blog" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; transition: border-color 0.2s; text-decoration: none;">
        <div style="font-size: 28px; margin-bottom: 12px;">🤖</div>
        <div style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 8px;">AI Agent 工作流</div>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          多 Agent 并行协作的实践。Codex 写代码、Hermes 管知识、TrendRadar 采信息——一个人指挥一支 AI 团队，关键是分工边界怎么定。
        </p>
      </a>

      <a href="/blog" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; transition: border-color 0.2s; text-decoration: none;">
        <div style="font-size: 28px; margin-bottom: 12px;">⚡</div>
        <div style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 8px;">超级个体实践</div>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          超级个体的本质不是一个人干十个人的活，而是通过系统设计获得杠杆。这是我的真实工作流、踩过的坑、和提炼出的方法。
        </p>
      </a>

      <a href="/blog" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; transition: border-color 0.2s; text-decoration: none;">
        <div style="font-size: 28px; margin-bottom: 12px;">✍️</div>
        <div style="font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 8px;">内容创作</div>
        <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          把实践过程变成可传播的内容。小红书图文 + 博客长文，不教方法论，只展示真实工作流。AI 超级个人的活标本。
        </p>
      </a>

    </div>
  </section>

  <!-- Blog -->
  <section style="padding: 40px 0;">
    <h2 style="font-size: 14px; font-weight: 700; color: var(--text-secondary); letter-spacing: 3px; margin-bottom: 24px; text-transform: uppercase;">最新文章</h2>
    <ul class="blog-list">
      {posts.slice(0, 5).map((entry) => (
        <li>
          <a href={`/blog/${entry.id}`} class="blog-item">
            <div class="blog-item-title">{entry.data.title}</div>
            <div class="blog-item-desc">{entry.data.description}</div>
            <div class="blog-item-meta">
              <span>{entry.data.date}</span>
              {entry.data.tags?.map((tag: string) => (
                <span class="blog-item-tag">{tag}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
    <a href="/blog" style="display: inline-block; margin-top: 24px; font-size: 15px; font-weight: 500;">
      查看全部文章 →
    </a>
  </section>
</BaseLayout>
